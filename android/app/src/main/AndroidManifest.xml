<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ─── Location Permissions ─────────────────────────────────────────────── -->
    <!-- Needed to show nearby chargers and center map on user position -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Background location for charging-network alerts (WorkManager) -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ─── Network ───────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:label="Plugoo"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true">

        <!-- ─── Google Maps API Key ──────────────────────────────────────────── -->
        <!-- Value is injected at build time from local.properties / CI secrets.  -->
        <!-- NEVER hardcode the key here.                                          -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${GOOGLE_MAPS_API_KEY}" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Edge-to-edge: gesture navigation bar is handled in Flutter via
                 WindowInsets. No special flags needed here — flutter_activity
                 handles the window fitting by default on API 30+. -->

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Don't delete the FlutterActivity metadata — needed by embedding v2. -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!-- Required by Google Play for apps targeting API 31+ -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <!-- Google Sign-In -->
        <package android:name="com.google.android.gms" />
    </queries>

</manifest>
